# Medical RAG Pipeline Configuration
# Copy to .env and update values for your environment

# =============================================================================
# QDRANT (SELF-HOSTED DEFAULT)
# =============================================================================
# Docker Compose on Hetzner should use the internal DNS host:
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=QDRANT_API_KEY_REDACTED
QDRANT_GRPC_URL=qdrant:6334
QDRANT_COLLECTION=rag_pipeline
COLLECTION_NAME=rag_pipeline  # Must match QDRANT_COLLECTION
QDRANT_CLOUD_INFERENCE=false
USE_GRPC=true

# =============================================================================
# API / CORS
# =============================================================================
# Comma-separated list of allowed browser origins.
# For production backend-only traffic, keep this minimal.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Service-to-service bearer auth
# Keep true in production. Set false only for local-only testing.
API_AUTH_ENABLED=true
API_KEYS_FILE=/opt/RAG-pipeline/api_keys.json
API_KEYS_CACHE_TTL_SECONDS=30

# Graceful shutdown / in-flight drain (seconds)
API_SHUTDOWN_GRACE_SECONDS=85
API_INFLIGHT_DRAIN_POLL_SECONDS=0.2

# =============================================================================
# CHUNKING & FILTERING (V4)
# =============================================================================
# Optimized for Qwen3-Embedding-0.6B (32k context window)
# Using 2048 tokens for maximum context per chunk
# Research shows 1024-2048 is optimal for medical QA with sufficient context
# With 32k context, 2048 is only 6.25% of capacity - very safe
# Overlap 12.5% (256 tokens) for good continuity without excessive redundancy
# 256 tokens provides sufficient context while keeping 87.5% unique content per chunk
EMBED_FILTER_ENABLED=true
EMBED_FILTER_MODE=conservative
EMBED_FILTER_PROFILE=clinical_backmatter
CHUNK_SIZE_TOKENS=2048
CHUNK_OVERLAP_TOKENS=256

# =============================================================================
# VECTOR QUANTIZATION (V5)
# =============================================================================
# Scalar quantization reduces memory by 75% (4x reduction) with <1% accuracy loss
# Options: scalar (int8, recommended), binary (faster, less accurate), none
QUANTIZATION_TYPE=scalar
SCALAR_QUANTILE=0.99
QUANTIZATION_ALWAYS_RAM=true
QUANTIZATION_RESCORE=true
QUANTIZATION_OVERSAMPLING=1.5

# =============================================================================
# EMBEDDINGS
# =============================================================================
# deepinfra
# Using Qwen3-Embedding-0.6B with 32k context window via DeepInfra
EMBEDDING_PROVIDER=deepinfra
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B-batch
EMBEDDING_BATCH_SIZE=64


# Sparse indexing / hybrid retrieval
SPARSE_ENABLED=true
SPARSE_MODE=bm25
USE_HYBRID_SEARCH=true
SPARSE_RETRIEVAL_MODE=bm25
SPARSE_MAX_TERMS_DOC=256
SPARSE_MAX_TERMS_QUERY=64
SPARSE_MIN_TOKEN_LEN=2
SPARSE_REMOVE_STOPWORDS=true

# =============================================================================
# DATA DIRECTORIES
# =============================================================================
DATA_DIR=/data/ingestion
PMC_XML_DIR=/data/ingestion/pmc_xml
DAILYMED_XML_DIR=/data/ingestion/dailymed/xml
DAILYMED_STATE_DIR=/data/ingestion/dailymed/state
DAILYMED_CHECKPOINT_FILE=/data/ingestion/dailymed_ingested_ids.txt
DAILYMED_SET_ID_MANIFEST=/data/ingestion/dailymed/state/dailymed_last_update_set_ids.txt
PUBMED_BASELINE_DIR=/data/ingestion/pubmed_baseline
PUBMED_ABSTRACTS_FILE=/data/ingestion/pubmed_baseline/filtered/pubmed_abstracts.jsonl

# =============================================================================
# INGESTION SETTINGS
# =============================================================================
# Safe default for large baseline ingests (helps avoid RocksDB "too many open files").
# After baseline completion and once collection state is stable, this can be raised to 50-100.
BATCH_SIZE=25
MAX_WORKERS=8
PARALLEL_WORKERS=8
MAX_RETRIES=3

# =============================================================================
# CHUNK RETRIEVAL / RERANK TUNING
# =============================================================================
# Optimized for Qwen3-Reranker-0.6B with larger context window
# Larger chunks need fewer candidates for good coverage
RETRIEVAL_CHUNK_LIMIT=400
MAX_CHUNKS_PER_ARTICLE_PRE_RERANK=2
RERANK_TOP_CHUNKS=100
FINAL_TOP_ARTICLES=50

# =============================================================================
# RERANKER (DeepInfra-only)
# Using Qwen3-Reranker-0.6B via DeepInfra
# =============================================================================
RERANKER_PROVIDER=deepinfra
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# =============================================================================
# LLM CONFIGURATION (DeepInfra)
# =============================================================================
LLM_MODEL=openai/gpt-oss-20b
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_CHAT_TIMEOUT_SECONDS=300
DEEPINFRA_EMBED_TIMEOUT_SECONDS=120
DEEPINFRA_RERANK_TIMEOUT_SECONDS=60

# =============================================================================
# QUERY CACHE
# =============================================================================
QUERY_CACHE_ENABLED=true
QUERY_CACHE_DIR=data/cache
QUERY_CACHE_EXPIRY_DAYS=30
# Bump either value to invalidate existing cache entries after major pipeline changes
QUERY_CACHE_NAMESPACE=default
QUERY_CACHE_KEY_VERSION=2

# =============================================================================
# RUNTIME API KEYS (DeepInfra-only)
# =============================================================================
DEEPINFRA_API_KEY=EtTTnU8SKGZowOdMTMVxCjtqsmC5VVd2
