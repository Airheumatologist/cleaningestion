# Medical RAG Pipeline Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# QDRANT CONFIGURATION
# =============================================================================
# Qdrant Cloud cluster URL (get from Qdrant Cloud dashboard)
QDRANT_URL=https://your-cluster-id.us-east-1-1.aws.cloud.qdrant.io:6333

# Qdrant API key (generate in Qdrant Cloud dashboard)
QDRANT_API_KEY=your_qdrant_api_key_here

# Collection name for the medical RAG pipeline
COLLECTION_NAME=pmc_medical_rag_fulltext

# =============================================================================
# DATA DIRECTORIES (for EC2)
# =============================================================================
# Base data directory
DATA_DIR=/data

# PMC data paths
PMC_XML_DIR=/data/pmc_fulltext/xml
PMC_JSONL_FILE=/data/pmc_articles.jsonl

# DailyMed data paths
DAILYMED_XML_DIR=/data/dailymed/xml
DAILYMED_JSONL_FILE=/data/dailymed_drugs.jsonl

# =============================================================================
# INGESTION SETTINGS
# =============================================================================
# Batch size for Cloud Inference (50 is optimal)
BATCH_SIZE=50

# Number of parallel workers (match shard count)
PARALLEL_WORKERS=4

# Maximum retries for failed batches
MAX_RETRIES=3
