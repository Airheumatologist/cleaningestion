# Cleaningestion — ingestion-only configuration.
# Copy to .env and fill in values for your environment.

# =============================================================================
# TURBOPUFFER (target vector store)
# =============================================================================
TURBOPUFFER_API_KEY=<set-turbopuffer-api-key>
TURBOPUFFER_REGION=gcp-us-central1
TURBOPUFFER_NAMESPACE_PMC=medical_database_pmc
TURBOPUFFER_NAMESPACE_PUBMED=medical_database_pubmed
TURBOPUFFER_NAMESPACE_DAILYMED=medical_database_dailymed
TURBOPUFFER_TIMEOUT_SECONDS=30
TURBOPUFFER_WRITE_BATCH_SIZE=500
TURBOPUFFER_MAX_CONCURRENT_WRITES=4
TURBOPUFFER_MAX_RETRIES=5
# Optional pacing between write batches per sink/namespace (seconds, 0 = disabled).
TURBOPUFFER_MIN_BATCH_INTERVAL_SECONDS=0
INGEST_DRY_RUN=false

# =============================================================================
# CHUNKING & FILTERING
# =============================================================================
EMBED_FILTER_ENABLED=true
EMBED_FILTER_MODE=conservative
EMBED_FILTER_PROFILE=clinical_backmatter
CHUNK_SIZE_TOKENS=2048
CHUNK_OVERLAP_TOKENS=256

# =============================================================================
# EMBEDDINGS (ingestion only)
# =============================================================================
EMBEDDING_PROVIDER=deepinfra
INGESTION_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B-batch
# Optional comma-separated failover chain.
INGESTION_EMBEDDING_MODELS=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_REQUESTS_PER_SEC=0
EMBEDDING_REQUEST_MAX_RETRIES=6
EMBEDDING_MAX_INPUT_TOKENS_PER_REQUEST=24000
EMBEDDING_MAX_TEXT_TOKENS=30000
EMBEDDING_MAX_CHARS_PER_TEXT=120000
EMBEDDING_CLIENT_COOLDOWN_SECONDS=15
EMBEDDING_CLIENT_FAILURE_THRESHOLD=2
EMBEDDING_RATE_LOG_ENABLED=true
EMBEDDING_RATE_LOG_WINDOW_SECONDS=10
EMBEDDING_RATE_LOG_EVERY_SECONDS=10

# DeepInfra account credentials (for embedding requests)
DEEPINFRA_API_KEY=<set-deepinfra-api-key>
# Optional multi-account failover/round-robin (comma-separated, unique values).
DEEPINFRA_API_KEYS=<set-deepinfra-key-1>,<set-deepinfra-key-2>
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_EMBED_TIMEOUT_SECONDS=120

# =============================================================================
# DATA DIRECTORIES
# =============================================================================
DATA_DIR=/data/ingestion
PMC_XML_DIR=/data/ingestion/pmc_xml
PMC_S3_CHECKPOINT_FILE=/data/ingestion/pmc_s3_ingested_ids.txt
PMC_S3_STATE_FILE=/data/ingestion/.pmc_s3_inventory_state.json
DAILYMED_CHECKPOINT_FILE=/data/ingestion/dailymed_ingested_ids.txt
PUBMED_BASELINE_DIR=/data/ingestion/pubmed_baseline
PUBMED_ABSTRACTS_FILE=/data/ingestion/pubmed_baseline/filtered/pubmed_abstracts.jsonl

# =============================================================================
# INGESTION SETTINGS
# =============================================================================
BATCH_SIZE=25
MAX_WORKERS=8
PARALLEL_WORKERS=8
MAX_RETRIES=3
PMC_S3_SUPER_BATCH_SIZE=250
PMC_S3_ARTICLE_QUEUE_SIZE=256
PMC_S3_POINTS_QUEUE_SIZE=32
PMC_S3_EMBED_ARTICLE_BATCH_SIZE=120
# Optional namespace sharding for PMC S3 ingest writes (default disabled).
PMC_S3_NAMESPACE_SHARD_COUNT=1
# Pattern supports {base} and {shard}; only used when shard count > 1.
PMC_S3_NAMESPACE_SHARD_PATTERN={base}_shard_{shard}

# Weekly update QoS controls
WEEKLY_UPDATE_THROTTLE_SECONDS=0.5
WEEKLY_UPDATE_BATCH_SIZE=0
